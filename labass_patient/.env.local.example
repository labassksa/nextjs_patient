# Labass Patient Portal - Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================================================
# EXISTING ENVIRONMENT VARIABLES (Keep your current values)
# ============================================================================

NEXT_PUBLIC_API_URL=https://api.test.labass.sa/api_labass
NEXT_PUBLIC_WEBSOCKET_URL=wss://api.test.labass.sa
NEXT_PUBLIC_LIVEKIT_URL=wss://labass-82ot742m.livekit.cloud

# ============================================================================
# PUSH NOTIFICATIONS - FIREBASE CLOUD MESSAGING (Required)
# ============================================================================
# Get these from Firebase Console: Project Settings > General

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================================
# PUSH NOTIFICATIONS - FIREBASE VAPID KEY (Required)
# ============================================================================
# Get this from Firebase Console: Project Settings > Cloud Messaging > Web Push certificates
# Click "Generate key pair" if you don't have one

NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ============================================================================
# PUSH NOTIFICATIONS - SAFARI WEB PUSH (Optional, for Safari iOS support)
# ============================================================================
# This is the Website Push ID you created in Apple Developer Portal
# Format: web.{domain}.{app}
# Leave as default if not using Safari push yet

NEXT_PUBLIC_SAFARI_WEB_PUSH_ID=web.sa.labass.patient

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. FIREBASE SETUP (for Chrome, Firefox, Edge, Android push notifications)
#    - Go to https://console.firebase.google.com
#    - Create new project or select existing project
#    - Go to Project Settings (gear icon) > General tab
#    - Scroll to "Your apps" section
#    - Click "Web app" icon (</>) to add web app
#    - Register app with nickname "Labass Patient Portal"
#    - Copy the config values to the FIREBASE_* variables above
#    - Go to Cloud Messaging tab
#    - Under "Web Push certificates", click "Generate key pair"
#    - Copy the key to NEXT_PUBLIC_FIREBASE_VAPID_KEY

# 2. SERVICE WORKER CONFIGURATION
#    - Open public/firebase-messaging-sw.js
#    - Replace placeholders with your actual Firebase config values:
#      * FIREBASE_API_KEY_PLACEHOLDER → Your API key
#      * FIREBASE_AUTH_DOMAIN_PLACEHOLDER → Your auth domain
#      * FIREBASE_PROJECT_ID_PLACEHOLDER → Your project ID
#      * FIREBASE_STORAGE_BUCKET_PLACEHOLDER → Your storage bucket
#      * FIREBASE_MESSAGING_SENDER_ID_PLACEHOLDER → Your sender ID
#      * FIREBASE_APP_ID_PLACEHOLDER → Your app ID

# 3. SAFARI WEB PUSH SETUP (Optional, for Safari iOS support)
#    - Requires Apple Developer account ($99/year)
#    - Create Website Push ID in Apple Developer Portal
#    - Set NEXT_PUBLIC_SAFARI_WEB_PUSH_ID to your Website Push ID
#    - Backend team will handle APNs certificate configuration
#    - See PUSH_NOTIFICATIONS_SETUP.md for detailed Safari setup

# 4. ASSET PREPARATION
#    - Generate notification icons (see public/icons/README.md)
#    - Add ringtone audio file (see public/sounds/README.md)
#    - Icons are required for good user experience
#    - Ringtone is required for incoming call notifications

# 5. TESTING
#    - Test on Chrome: Should request permission and generate FCM token
#    - Test on Firefox: Should work same as Chrome
#    - Test on Safari desktop: Should work with FCM
#    - Test on Safari iOS: Requires Safari Web Push ID and APNs setup
#    - Use browser DevTools > Application > Service Workers to debug

# 6. DEPLOYMENT
#    - Ensure all environment variables are set in production
#    - Update service worker with production Firebase config
#    - Deploy to HTTPS domain (required for push notifications)
#    - Verify manifest.json is accessible at /manifest.json
#    - Test notification permission request on production

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# Issue: "Firebase messaging not supported"
# Solution: Ensure you're on HTTPS or localhost, check browser compatibility

# Issue: "VAPID key not configured"
# Solution: Generate VAPID key in Firebase Console and add to .env.local

# Issue: Service worker not updating
# Solution: Clear browser cache, unregister old service workers, hard refresh

# Issue: Notifications not appearing
# Solution: Check permission is granted, verify backend is sending notifications

# Issue: Safari not working
# Solution: Ensure APNS_* variables are set in backend, verify Website Push ID

